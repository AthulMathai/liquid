# ============================================
# SUPABASE
# ============================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# SUPABASE STORAGE
# ============================================

SUPABASE_STORAGE_BUCKET=product-images

# ============================================
# NETLIFY
# ============================================

NETLIFY=true

# ============================================
# APP SETTINGS
# ============================================

NEXT_PUBLIC_APP_NAME=Liquidation Hub
NEXT_PUBLIC_DEFAULT_CURRENCY=CAD
NEXT_PUBLIC_DEFAULT_LOCALE=en-CA

# ============================================
# IMAGE SETTINGS
# ============================================

NEXT_PUBLIC_MAX_IMAGE_UPLOAD=10
NEXT_PUBLIC_MAX_IMAGE_SIZE_MB=10

# ============================================
# SCANNER SETTINGS
# ============================================

NEXT_PUBLIC_SCANNER_TIMEOUT_MS=1500
NEXT_PUBLIC_SCANNER_MIN_LENGTH=4